{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/kinto-pitch/((?!.*\\.).*)", "destination": "/kinto-pitch/index.html" },
    { "source": "/random-pitch/((?!.*\\.).*)", "destination": "/random-pitch/index.html" },
    { "source": "/((?!.*\\.).*)", "destination": "/index.html" }
  ]
}
